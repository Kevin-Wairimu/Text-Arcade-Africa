# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/text-arcade-africa

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# SMTP Configuration (for Contact & Feedback)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password

# Email Configuration (for Auth/Password Reset)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password

# Receiver for Contact Form
CONTACT_RECEIVER=admin@example.com

# Cloudflare Configuration (Optional)
CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_cloudflare_account_id
